# Copy to .env in the directory you run a service from (each service loads ./.env).

# --- credentials (set the one(s) your chosen providers need) ---
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- provider selection (defaults shown; switching providers = editing these lines only) ---
FMA_LLM_PROVIDER=gemini            # gemini | openai | anthropic
FMA_LLM_MODEL=gemini-2.5-flash
FMA_EMBEDDING_PROVIDER=gemini      # gemini | openai | local
FMA_EMBEDDING_MODEL=gemini-embedding-001
FMA_LOG_LEVEL=INFO

# Keyless development: FMA_EMBEDDING_PROVIDER=local uses an offline ONNX model.
# Retrieval and the retrieval eval work with no API key; generation needs an LLM key.
